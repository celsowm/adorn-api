    "express": "^5.2.1",
    "fastify": "^5.8.4",
    "metal-orm": "^1.1.10"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/sqlite3": "^5.1.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/mocker": "^4.1.2",
    "eslint": "^10.1.0",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "tedious": "^19.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
