{
  "name": "adorn-api",
  "version": "1.1.11",
  "description": "Decorator-first web framework with OpenAPI 3.1 schema generation.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx examples/basic/index.ts",
